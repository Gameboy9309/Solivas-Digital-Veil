---
layout: base.njk
title: Blog
permalink: /blog/
---

<div class="page-header">
  <h1>Blog</h1>
  <p class="page-description">Long-form writing on things I find interesting.</p>
</div>

<div class="post-list">
  {% for post in collections.blog %}
    <a class="card" href="{{ post.url }}">
      <div class="post-card-meta">{{ post.date | readableDate }}</div>
      <div class="post-card-title">{{ post.data.title }}</div>
      {% if post.data.excerpt %}
        <p class="post-card-excerpt">{{ post.data.excerpt }}</p>
      {% endif %}
      {% if post.data.topics %}
        <div class="tags">
          {% for t in post.data.topics %}
            <span class="tag">{{ t }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </a>
  {% else %}
    <p class="empty-state">Nothing here yet — first post coming soon.</p>
  {% endfor %}
</div>
